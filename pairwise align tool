        setSize(1100, 750); setDefaultCloseOperation(EXIT_ON_CLOSE);
        setLocationRelativeTo(null);
        getContentPane().setBackground(BG);
        setLayout(new BorderLayout());

        // ── Header ──
        JLabel title = new JLabel("⬡  Pairwise Sequence Alignment Tool");
        title.setFont(new Font("Monospaced",Font.BOLD,19)); title.setForeground(GREEN);
        JLabel sub = new JLabel("Needleman-Wunsch (Global)  ·  Smith-Waterman (Local)");
        sub.setFont(new Font("SansSerif",Font.PLAIN,12)); sub.setForeground(MUTED);
        JPanel tp = new JPanel(new GridLayout(2,1,0,3)); tp.setOpaque(false);
        tp.add(title); tp.add(sub);
        JPanel header = new JPanel(new BorderLayout());
        header.setBackground(CARD); header.setBorder(BorderFactory.createEmptyBorder(14,24,14,24));
        header.add(tp, BorderLayout.WEST);

        // ── Left Panel: inputs + settings + button ──
        seq1 = textBox(); seq1.setText("AGCTGATCGATCGTAGCTA");
        seq2 = textBox(); seq2.setText("AGCTGATCGTAGCTAGCTA");

        algoCB    = combo("Needleman-Wunsch (Global)","Smith-Waterman (Local)");
        typeCB    = combo("DNA","RNA","Protein");
        matchSp   = spinner(1,  -10, 10);  // reward for match
        mismatchSp= spinner(-1, -10, 0);   // penalty for mismatch
        gapSp     = spinner(-2, -10, 0);   // penalty for gap

        JButton alignBtn = btn("▶  ALIGN SEQUENCES", GREEN);
        alignBtn.setPreferredSize(new Dimension(0,46));
        alignBtn.setFont(new Font("Monospaced",Font.BOLD,14));
        alignBtn.addActionListener(e -> runAlignment());

        // Settings card
        JPanel settings = card();
        settings.setLayout(new java.awt.GridBagLayout());
        java.awt.GridBagConstraints g = new java.awt.GridBagConstraints();
        g.fill=java.awt.GridBagConstraints.HORIZONTAL; g.insets=new Insets(4,4,4,4);
        String[]    lbls  = {"Algorithm","Sequence Type","Match","Mismatch","Gap"};
        Component[] ctrls = {algoCB, typeCB, matchSp, mismatchSp, gapSp};
        for (int i=0;i<lbls.length;i++){
            g.gridx=0; g.gridy=i; g.weightx=0.4; settings.add(muted(lbls[i]),g);
            g.gridx=1;            g.weightx=0.6; settings.add(ctrls[i],g);
        }

        JPanel left = new JPanel(new BorderLayout(0,10));
        left.setBackground(BG); left.setBorder(BorderFactory.createEmptyBorder(14,14,14,8));
        JPanel seqs = new JPanel(new GridLayout(2,1,0,10)); seqs.setOpaque(false);
        seqs.add(seqCard("Sequence 1", seq1, BLUE));
