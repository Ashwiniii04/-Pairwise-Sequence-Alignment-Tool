    //  ALIGNMENT LOGIC
    void runAlignment() {
        String s1 = seq1.getText().trim().toUpperCase().replaceAll("\\s+","");
        String s2 = seq2.getText().trim().toUpperCase().replaceAll("\\s+","");
        if (s1.isEmpty()||s2.isEmpty()){ JOptionPane.showMessageDialog(this,"Enter both sequences!"); return; }

        int match = (int)matchSp.getValue(), mm = (int)mismatchSp.getValue(), gap = (int)gapSp.getValue();
        boolean global = algoCB.getSelectedIndex()==0; // 0=NW global, 1=SW local

        int[][] dp = global ? nwMatrix(s1,s2,match,mm,gap) : swMatrix(s1,s2,match,mm,gap);
        int   score = global ? dp[s1.length()][s2.length()] : maxVal(dp);
        int[] start = global ? new int[]{s1.length(),s2.length()} : maxPos(dp);

        String[] al = traceback(dp,s1,s2,start[0],start[1],gap,match,mm,!global);
        showResult(al, score, global);
    }

    // Needleman-Wunsch: fill DP matrix (global — initialise edges with gap penalties)
    int[][] nwMatrix(String s1, String s2, int match, int mm, int gap) {
        int m=s1.length(), n=s2.length();
        int[][] dp = new int[m+1][n+1];
        for (int i=0;i<=m;i++) dp[i][0]=i*gap;   // gap penalty for first column
        for (int j=0;j<=n;j++) dp[0][j]=j*gap;   // gap penalty for first row
        for (int i=1;i<=m;i++) for (int j=1;j<=n;j++) {
            int d = dp[i-1][j-1]+(s1.charAt(i-1)==s2.charAt(j-1)?match:mm); // diagonal
            dp[i][j] = Math.max(d, Math.max(dp[i-1][j]+gap, dp[i][j-1]+gap));
        }
        return dp;
    }

    // Smith-Waterman: fill DP matrix (local — no negative scores, reset to 0)
    int[][] swMatrix(String s1, String s2, int match, int mm, int gap) {
        int m=s1.length(), n=s2.length();
        int[][] dp = new int[m+1][n+1];
        for (int i=1;i<=m;i++) for (int j=1;j<=n;j++) {
            int d = dp[i-1][j-1]+(s1.charAt(i-1)==s2.charAt(j-1)?match:mm);
            dp[i][j] = Math.max(0, Math.max(d, Math.max(dp[i-1][j]+gap, dp[i][j-1]+gap)));
        }
        return dp;
    }

    // Traceback: walk back through DP matrix to reconstruct aligned strings
    String[] traceback(int[][] dp, String s1, String s2, int i, int j,
                       int gap, int match, int mm, boolean local) {
        StringBuilder a1=new StringBuilder(), a2=new StringBuilder(), mid=new StringBuilder();
        while (i>0||j>0) {
            if (local && dp[i][j]==0) break;          // SW: stop at zero cell
            if (i>0&&j>0) {
                int ds = s1.charAt(i-1)==s2.charAt(j-1)?match:mm;
                if (dp[i][j]==dp[i-1][j-1]+ds) {     // came from diagonal = match/mismatch
                    a1.insert(0,s1.charAt(i-1)); a2.insert(0,s2.charAt(j-1));
                    mid.insert(0,s1.charAt(i-1)==s2.charAt(j-1)?'|':'X'); i--;j--; continue;
                }
            }
            if (i>0&&dp[i][j]==dp[i-1][j]+gap) {     // came from above = gap in seq2
                a1.insert(0,s1.charAt(i-1)); a2.insert(0,'-'); mid.insert(0,' '); i--;
            } else {                                   // came from left = gap in seq1
                a1.insert(0,'-'); a2.insert(0,s2.charAt(j-1)); mid.insert(0,' '); j--;
            }
        }
        return new String[]{a1.toString(),a2.toString(),mid.toString()};
    }

    // Display results in result panel and update stat cards
    void showResult(String[] al, int score, boolean global) {
        String a1=al[0], a2=al[1], mid=al[2];
        int len=a1.length(), matches=count(mid,'|'), mm=count(mid,'X');
        int gaps=count(a1,'-')+count(a2,'-');
        double id = len>0 ? matches*100.0/len : 0;

        scoreLbl.setText(String.valueOf(score));
        idLbl   .setText(String.format("%.1f%%",id));
        gapLbl  .setText(String.valueOf(gaps));
        mmLbl   .setText(String.valueOf(mm));

        StringBuilder sb = new StringBuilder();
        sb.append("═══════════════════════════════════════════\n");
        sb.append("  Algorithm : ").append(global?"Needleman-Wunsch (Global)":"Smith-Waterman (Local)").append("\n");
        sb.append("  Type      : ").append(typeCB.getSelectedItem()).append("\n");
        sb.append(String.format("  Score     : %d%n  Identity  : %.1f%% (%d/%d)%n  Gaps      : %d%n  Mismatches: %d%n",
                score,id,matches,len,gaps,mm));
        sb.append("═══════════════════════════════════════════\n\n");
        // Print alignment in blocks of 60 (standard bioinformatics format)
        for (int s=0;s<len;s+=60) {
            int e=Math.min(s+60,len);
            sb.append(String.format("  Seq1 %4d  %s  %d%n",s+1,a1.substring(s,e),e));
            sb.append(String.format("             %s%n",mid.substring(s,e)));
            sb.append(String.format("  Seq2 %4d  %s  %d%n%n",s+1,a2.substring(s,e),e));
        }
        sb.append("  Legend:  | = Match   X = Mismatch   (space) = Gap\n");
        sb.append("═══════════════════════════════════════════\n");
        result.setText(sb.toString()); result.setCaretPosition(0);
    }
    //  HELPERS
    int count(String s, char c) { int n=0; for (char ch:s.toCharArray()) if(ch==c) n++; return n; }
    int maxVal(int[][] dp)      { int m=0; for(int[]r:dp) for(int v:r) if(v>m) m=v; return m; }
    int[] maxPos(int[][] dp)    { int m=0,pi=0,pj=0;
        for(int i=0;i<dp.length;i++) for(int j=0;j<dp[0].length;j++)
            if(dp[i][j]>m){m=dp[i][j];pi=i;pj=j;} return new int[]{pi,pj}; }

    JTextArea textBox() {
        JTextArea ta=new JTextArea(4,20); ta.setFont(new Font("Monospaced",Font.PLAIN,13));
        ta.setBackground(INPUT); ta.setForeground(TEXT); ta.setCaretColor(GREEN);
        ta.setLineWrap(true); ta.setBorder(BorderFactory.createEmptyBorder(6,8,6,8)); return ta;
    }
    JPanel seqCard(String label, JTextArea ta, Color accent) {
        JPanel c=card(); c.setLayout(new BorderLayout(0,6));
        JLabel l=new JLabel(label); l.setFont(new Font("Monospaced",Font.BOLD,11)); l.setForeground(accent);
        c.add(l,BorderLayout.NORTH); c.add(new JScrollPane(ta),BorderLayout.CENTER); return c;
    }
    JLabel statCard(JPanel parent, String title, String val, Color accent) {
        JPanel c=new JPanel(new GridLayout(2,1,0,4)); c.setBackground(CARD);
        c.setBorder(BorderFactory.createCompoundBorder(
                BorderFactory.createMatteBorder(0,3,0,0,accent),
                BorderFactory.createEmptyBorder(10,12,10,12)));
        JLabel tl=new JLabel(title); tl.setFont(new Font("SansSerif",Font.PLAIN,10)); tl.setForeground(MUTED);
        JLabel vl=new JLabel(val);   vl.setFont(new Font("Monospaced",Font.BOLD,18)); vl.setForeground(accent);
        c.add(tl); c.add(vl); parent.add(c); return vl;
    }
    JPanel card() {
        JPanel p=new JPanel(); p.setBackground(CARD);
        p.setBorder(BorderFactory.createCompoundBorder(
                BorderFactory.createLineBorder(INPUT,1), BorderFactory.createEmptyBorder(10,12,10,12))); return p;
    }
    JComboBox<String> combo(String... items) {
        JComboBox<String> cb=new JComboBox<>(items);
        cb.setFont(new Font("SansSerif",Font.PLAIN,12)); cb.setBackground(INPUT); cb.setForeground(TEXT); return cb;
    }
    JSpinner spinner(int val, int min, int max) {
        JSpinner s=new JSpinner(new SpinnerNumberModel(val,min,max,1));
        s.setFont(new Font("Monospaced",Font.PLAIN,12));
        ((JSpinner.DefaultEditor)s.getEditor()).getTextField().setBackground(INPUT);
        ((JSpinner.DefaultEditor)s.getEditor()).getTextField().setForeground(TEXT); return s;
    }
    JLabel muted(String t) {
        JLabel l=new JLabel(t); l.setFont(new Font("SansSerif",Font.PLAIN,12)); l.setForeground(MUTED); return l;
    }
    JButton btn(String text, Color c) {
        JButton b=new JButton(text){
            protected void paintComponent(Graphics g){
                Graphics2D g2=(Graphics2D)g.create();
                g2.setRenderingHint(RenderingHints.KEY_ANTIALIASING,RenderingHints.VALUE_ANTIALIAS_ON);
                g2.setColor(getModel().isRollover()?c.darker():CARD);
                g2.fillRoundRect(0,0,getWidth(),getHeight(),8,8);
                g2.setColor(c); g2.setStroke(new BasicStroke(1.5f));
                g2.drawRoundRect(1,1,getWidth()-2,getHeight()-2,8,8);
                g2.dispose(); super.paintComponent(g);
            }
        };
        b.setForeground(c); b.setFont(new Font("Monospaced",Font.BOLD,12));
        b.setContentAreaFilled(false); b.setBorderPainted(false); b.setFocusPainted(false);
        b.setCursor(Cursor.getPredefinedCursor(Cursor.HAND_CURSOR));
        b.setPreferredSize(new Dimension(0,36)); return b;
    }

    public static void main(String[] args){ SwingUtilities.invokeLater(PairwiseAlignmentTool::new); }
