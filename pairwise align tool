import java.awt.*;
import java.io.*;
public class PairwiseAlignmentTool extends JFrame {

    // ── UI Fields ──
    JTextArea seq1, seq2, result;
    JLabel    scoreLbl, idLbl, gapLbl, mmLbl;
    JComboBox<String> algoCB, typeCB;
    JSpinner  matchSp, mismatchSp, gapSp;

    // ── Colors ──
    static final Color BG    = new Color(15,23,42),   CARD  = new Color(30,41,59),
            INPUT = new Color(51,65,85),   GREEN = new Color(52,211,153),
            BLUE  = new Color(96,165,250), RED   = new Color(248,113,113),
            AMBER = new Color(251,191,36), TEXT  = new Color(226,232,240),
            MUTED = new Color(148,163,184);

    //  CONSTRUCTOR — builds full UI
    public PairwiseAlignmentTool() {
